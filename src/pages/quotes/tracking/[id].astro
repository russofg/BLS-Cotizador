---
import Dashboard from "../../../layouts/Dashboard.astro";
import ScrollbarStyles from "../../../components/ScrollbarStyles.astro";
import { QuoteTrackingService, QuoteStatus } from "../../../services/QuoteTrackingService";
import { QuoteHelper } from "../../../utils/quoteHelpers";

const ARGENTINA_TIMEZONE = "America/Argentina/Buenos_Aires";
const formatArgentinaDateTime = (value: string | Date) =>
  new Intl.DateTimeFormat("es-AR", {
    timeZone: ARGENTINA_TIMEZONE,
    year: "numeric",
    month: "2-digit",
    day: "2-digit",
    hour: "2-digit",
    minute: "2-digit",
    hour12: false,
  }).format(new Date(value));

export async function getStaticPaths() {
  return [];
}

const { id } = Astro.params;

let quoteTracking: any = null;
let error = "";

try {
  if (id) {
    quoteTracking = await QuoteTrackingService.getByIdWithTracking(id);
    if (!quoteTracking) error = "Cotización no encontrada";
  } else {
    error = "ID de cotización no proporcionado";
  }
} catch (err) {
  console.error("Error loading quote tracking:", err);
  error = "Error al cargar el seguimiento de la cotización";
}

const getAvailableStatuses = (currentStatus: QuoteStatus): QuoteStatus[] => {
  const transitions: Record<QuoteStatus, QuoteStatus[]> = {
    [QuoteStatus.BORRADOR]:   [QuoteStatus.ENVIADA, QuoteStatus.RECHAZADA],
    [QuoteStatus.ENVIADA]:    [QuoteStatus.REVISADA, QuoteStatus.RECHAZADA, QuoteStatus.VENCIDA],
    [QuoteStatus.REVISADA]:   [QuoteStatus.APROBADA, QuoteStatus.RECHAZADA, QuoteStatus.VENCIDA],
    [QuoteStatus.APROBADA]:   [QuoteStatus.CONVERTIDA],
    [QuoteStatus.RECHAZADA]:  [QuoteStatus.BORRADOR],
    [QuoteStatus.VENCIDA]:    [QuoteStatus.BORRADOR],
    [QuoteStatus.CONVERTIDA]: [QuoteStatus.APROBADA],
  };
  return transitions[currentStatus] || [];
};

function getStatusBadge(estado: string) {
  const norm = QuoteHelper.normalizeQuoteStatus(estado);
  if (norm === 'aprobada')   return { badge: "bg-emerald-500/10 text-emerald-400 border-emerald-500/20", dot: "bg-emerald-500", label: "Aprobada" };
  if (norm === 'enviada')    return { badge: "bg-blue-500/10 text-blue-400 border-blue-500/20",          dot: "bg-blue-500",    label: "Enviada" };
  if (norm === 'rechazada')  return { badge: "bg-red-500/10 text-red-400 border-red-500/20",             dot: "bg-red-500",     label: "Rechazada" };
  if (norm === 'vencida')    return { badge: "bg-orange-500/10 text-orange-400 border-orange-500/20",    dot: "bg-orange-500",  label: "Vencida" };
  if (norm === 'revisada')   return { badge: "bg-amber-500/10 text-amber-400 border-amber-500/20",       dot: "bg-amber-500",   label: "Revisada" };
  if (norm === 'convertida') return { badge: "bg-violet-500/10 text-violet-400 border-violet-500/20",    dot: "bg-violet-500",  label: "Facturada" };
  if (norm === 'pendiente')  return { badge: "bg-amber-500/10 text-amber-400 border-amber-500/20",       dot: "bg-amber-500",   label: "Pendiente" };
  return { badge: "bg-slate-500/10 text-slate-400 border-slate-500/20", dot: "bg-slate-500", label: "Borrador" };
}

function getStatusActionLabel(status: QuoteStatus): string {
  switch (status) {
    case QuoteStatus.ENVIADA:    return "Marcar como Enviada";
    case QuoteStatus.REVISADA:   return "Marcar como Revisada";
    case QuoteStatus.APROBADA:   return "Aprobar Cotización";
    case QuoteStatus.RECHAZADA:  return "Rechazar Cotización";
    case QuoteStatus.CONVERTIDA: return "Marcar como Facturada";
    default:                     return "Volver a Borrador";
  }
}

function getStatusActionIcon(status: QuoteStatus): string {
  switch (status) {
    case QuoteStatus.ENVIADA:    return "send";
    case QuoteStatus.REVISADA:   return "rate_review";
    case QuoteStatus.APROBADA:   return "check_circle";
    case QuoteStatus.RECHAZADA:  return "cancel";
    case QuoteStatus.CONVERTIDA: return "swap_horiz";
    default:                     return "undo";
  }
}

function getStatusActionColor(status: QuoteStatus): string {
  switch (status) {
    case QuoteStatus.APROBADA:   return "border-emerald-500/30 text-emerald-400 hover:bg-emerald-500/10";
    case QuoteStatus.RECHAZADA:  return "border-red-500/30 text-red-400 hover:bg-red-500/10";
    case QuoteStatus.ENVIADA:    return "border-blue-500/30 text-blue-400 hover:bg-blue-500/10";
    case QuoteStatus.REVISADA:   return "border-amber-500/30 text-amber-400 hover:bg-amber-500/10";
    case QuoteStatus.CONVERTIDA: return "border-violet-500/30 text-violet-400 hover:bg-violet-500/10";
    default:                     return "border-slate-500/30 text-slate-400 hover:bg-slate-500/10";
  }
}

const statusBadge    = quoteTracking ? getStatusBadge(quoteTracking.estado) : null;
const availableNextStatuses = quoteTracking ? getAvailableStatuses(quoteTracking.estado) : [];
const diasVenc       = quoteTracking?.diasVencimiento ?? 0;
---

<Dashboard title={`Seguimiento · ${quoteTracking?.numero ?? "..."} - BLS Cotizador`} activeSection="quotes">
  <ScrollbarStyles />
  <div class="space-y-6 pb-12">

    <!-- ── Header ──────────────────────────────────────────────────────────── -->
    <section class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
      <div>
        <nav class="flex items-center gap-2 mb-2">
          <a href="/quotes" class="text-[10px] font-bold tracking-widest text-[var(--color-on-surface-variant)] uppercase hover:text-[var(--color-primary)] transition-colors">Cotizaciones</a>
          <span class="material-symbols-outlined text-xs text-[var(--color-outline)]">chevron_right</span>
          {quoteTracking && (
            <a href={`/quotes/view/${quoteTracking.id}`} class="text-[10px] font-bold tracking-widest text-[var(--color-on-surface-variant)] uppercase hover:text-[var(--color-primary)] transition-colors font-mono">{quoteTracking.numero}</a>
          )}
          <span class="material-symbols-outlined text-xs text-[var(--color-outline)]">chevron_right</span>
          <span class="text-[10px] font-bold tracking-widest text-[var(--color-primary)] uppercase">Seguimiento</span>
        </nav>
        <h2 class="text-3xl font-black tracking-tight text-[var(--color-on-surface)]">Seguimiento</h2>
        {quoteTracking && (
          <p class="text-[var(--color-on-surface-variant)] mt-1 text-sm">{quoteTracking.titulo} · {quoteTracking.clienteNombre}</p>
        )}
      </div>
      <div class="flex items-center gap-2 flex-wrap">
        <a href="/quotes" class="flex items-center gap-2 px-4 py-2.5 rounded-xl font-bold text-sm border border-[var(--color-outline-variant)] text-[var(--color-on-surface)] hover:bg-[var(--color-surface-container-high)] transition-all">
          <span class="material-symbols-outlined text-lg">arrow_back</span>
          Volver
        </a>
        {quoteTracking && (
          <a href={`/quotes/view/${quoteTracking.id}`} class="flex items-center gap-2 bg-gradient-to-br from-blue-500 to-blue-700 text-white px-5 py-2.5 rounded-xl font-bold text-sm shadow-[0_4px_12px_rgba(59,130,246,0.3)] hover:scale-[1.02] transition-all">
            <span class="material-symbols-outlined text-lg">description</span>
            Ver Cotización
          </a>
        )}
      </div>
    </section>

    {error && (
      <div class="flex items-center gap-4 bg-red-500/10 border border-red-500/20 text-red-400 px-6 py-5 rounded-xl">
        <span class="material-symbols-outlined text-2xl">error</span>
        <p>{error}</p>
      </div>
    )}

    {quoteTracking && (
      <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">

        <!-- ── LEFT: 2/3 ─────────────────────────────────────────────────── -->
        <div class="xl:col-span-2 space-y-6">

          <!-- Info card -->
          <div class="bg-[var(--color-surface-container-low)] rounded-xl border border-[var(--color-outline-variant)]/50 shadow-[0_12px_32px_rgba(0,0,0,0.3)] overflow-hidden">
            <div class="px-6 py-4 border-b border-[var(--color-outline-variant)]/40 flex items-center gap-2">
              <span class="material-symbols-outlined text-lg text-[var(--color-primary)]">info</span>
              <h3 class="font-black text-[var(--color-on-surface)] uppercase tracking-widest text-xs">Detalles de la Cotización</h3>
            </div>
            <div class="p-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div class="bg-[var(--color-surface-container)] rounded-xl p-4 border border-[var(--color-outline-variant)]/30">
                <p class="text-[10px] font-black uppercase tracking-widest text-[var(--color-on-surface-variant)] mb-1">Número</p>
                <p class="font-black text-[var(--color-on-surface)] font-mono">{quoteTracking.numero}</p>
              </div>
              <div class="bg-[var(--color-surface-container)] rounded-xl p-4 border border-[var(--color-outline-variant)]/30">
                <p class="text-[10px] font-black uppercase tracking-widest text-[var(--color-on-surface-variant)] mb-1">Cliente</p>
                <p class="font-bold text-[var(--color-on-surface)] text-sm">{quoteTracking.clienteNombre}</p>
              </div>
              <div class="bg-[var(--color-surface-container)] rounded-xl p-4 border border-[var(--color-outline-variant)]/30">
                <p class="text-[10px] font-black uppercase tracking-widest text-[var(--color-on-surface-variant)] mb-1">Título</p>
                <p class="font-bold text-[var(--color-on-surface)] text-sm">{quoteTracking.titulo}</p>
              </div>
              <div class="bg-[var(--color-surface-container)] rounded-xl p-4 border border-[var(--color-outline-variant)]/30">
                <p class="text-[10px] font-black uppercase tracking-widest text-[var(--color-on-surface-variant)] mb-1">Total</p>
                <p class="font-black text-[var(--color-primary)] text-lg"><span class="text-sm font-medium mr-0.5">$</span>{quoteTracking.total.toLocaleString("es-AR")}</p>
              </div>
              {quoteTracking.observaciones && (
                <div class="sm:col-span-2 bg-[var(--color-surface-container)] rounded-xl p-4 border border-[var(--color-outline-variant)]/30">
                  <p class="text-[10px] font-black uppercase tracking-widest text-[var(--color-on-surface-variant)] mb-1">Observaciones</p>
                  <p class="text-sm text-[var(--color-on-surface)] leading-relaxed">{quoteTracking.observaciones}</p>
                </div>
              )}
            </div>
          </div>

          <!-- Cambiar Estado -->
          <div class="bg-[var(--color-surface-container-low)] rounded-xl border border-[var(--color-outline-variant)]/50 shadow-[0_12px_32px_rgba(0,0,0,0.3)] overflow-hidden">
            <div class="px-6 py-4 border-b border-[var(--color-outline-variant)]/40 flex items-center gap-2">
              <span class="material-symbols-outlined text-lg text-[var(--color-primary)]">swap_horiz</span>
              <h3 class="font-black text-[var(--color-on-surface)] uppercase tracking-widest text-xs">Cambiar Estado</h3>
            </div>
            <div class="p-6">
              {availableNextStatuses.length > 0 ? (
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
                  {availableNextStatuses.map((status) => {
                    const color = getStatusActionColor(status);
                    const icon  = getStatusActionIcon(status);
                    const label = getStatusActionLabel(status);
                    return (
                      <button
                        onclick={`changeStatus('${status}', '${quoteTracking.id}')`}
                        class={`flex items-center gap-3 p-4 rounded-xl border font-bold text-sm transition-all hover:-translate-y-0.5 ${color}`}
                      >
                        <span class="material-symbols-outlined text-xl">{icon}</span>
                        <span>{label}</span>
                      </button>
                    );
                  })}
                </div>
              ) : (
                <div class="flex items-center gap-3 text-[var(--color-on-surface-variant)] text-sm py-4">
                  <span class="material-symbols-outlined opacity-40">block</span>
                  No hay transiciones disponibles desde el estado actual.
                </div>
              )}
            </div>
          </div>

          <!-- Historial de Cambios -->
          {quoteTracking.historialCambios?.length > 0 && (
            <div class="bg-[var(--color-surface-container-low)] rounded-xl border border-[var(--color-outline-variant)]/50 shadow-[0_12px_32px_rgba(0,0,0,0.3)] overflow-hidden">
              <div class="px-6 py-4 border-b border-[var(--color-outline-variant)]/40 flex items-center gap-2">
                <span class="material-symbols-outlined text-lg text-[var(--color-primary)]">history</span>
                <h3 class="font-black text-[var(--color-on-surface)] uppercase tracking-widest text-xs">Historial de Cambios</h3>
                <span class="ml-auto text-[10px] font-black bg-[var(--color-primary)]/10 text-[var(--color-primary)] border border-[var(--color-primary)]/20 px-2 py-0.5 rounded-full">{quoteTracking.historialCambios.length}</span>
              </div>
              <div class="divide-y divide-[var(--color-outline-variant)]/20">
                {quoteTracking.historialCambios.map((cambio: any, index: number) => {
                  const from = getStatusBadge(cambio.estadoAnterior);
                  const to   = getStatusBadge(cambio.estadoNuevo);
                  return (
                    <div class="flex items-center gap-4 px-6 py-4">
                      <div class={`w-7 h-7 rounded-lg flex items-center justify-center text-[10px] font-black shrink-0 bg-[var(--color-primary)]/10 text-[var(--color-primary)]`}>{quoteTracking.historialCambios.length - index}</div>
                      <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-2 flex-wrap mb-1">
                          <span class={`px-2 py-0.5 text-[9px] font-black uppercase tracking-widest rounded-full border ${from.badge}`}>{from.label}</span>
                          <span class="material-symbols-outlined text-sm text-[var(--color-on-surface-variant)]">arrow_forward</span>
                          <span class={`px-2 py-0.5 text-[9px] font-black uppercase tracking-widest rounded-full border ${to.badge}`}>{to.label}</span>
                        </div>
                        <p class="text-xs text-[var(--color-on-surface-variant)]">
                          {new Date(cambio.fecha).toLocaleString("es-AR")}
                          {cambio.usuario && ` · ${cambio.usuario}`}
                          {cambio.comentario && ` · ${cambio.comentario}`}
                        </p>
                      </div>
                    </div>
                  );
                })}
              </div>
            </div>
          )}
        </div>

        <!-- ── RIGHT: 1/3 ─────────────────────────────────────────────────── -->
        <div class="space-y-6">

          <!-- Estado Actual -->
          <div class="bg-[var(--color-surface-container-low)] rounded-xl border border-[var(--color-outline-variant)]/50 shadow-[0_12px_32px_rgba(0,0,0,0.3)] p-6">
            <p class="text-[10px] font-black uppercase tracking-widest text-[var(--color-on-surface-variant)] mb-4">Estado Actual</p>
            {statusBadge && (
              <div class="flex items-center gap-2 mb-6">
                <span class={`w-2.5 h-2.5 rounded-full shrink-0 ${statusBadge.dot}`}></span>
                <span class={`px-3 py-1 text-xs font-black uppercase tracking-widest rounded-full border ${statusBadge.badge}`}>{statusBadge.label}</span>
              </div>
            )}
            <div class="space-y-3">
              <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-base text-[var(--color-primary)] opacity-70">event</span>
                <div>
                  <p class="text-[9px] uppercase tracking-widest text-[var(--color-on-surface-variant)]">Creación</p>
                  <p class="font-bold text-[var(--color-on-surface)] text-sm">{quoteTracking.fechaCreacion.toLocaleDateString("es-AR")}</p>
                </div>
              </div>
              {quoteTracking.fechaEnvio && (
                <div class="flex items-center gap-3">
                  <span class="material-symbols-outlined text-base text-blue-400 opacity-70">send</span>
                  <div>
                    <p class="text-[9px] uppercase tracking-widest text-[var(--color-on-surface-variant)]">Enviada</p>
                    <p class="font-bold text-[var(--color-on-surface)] text-sm">{quoteTracking.fechaEnvio.toLocaleDateString("es-AR")}</p>
                  </div>
                </div>
              )}
              {quoteTracking.fechaRevision && (
                <div class="flex items-center gap-3">
                  <span class="material-symbols-outlined text-base text-amber-400 opacity-70">rate_review</span>
                  <div>
                    <p class="text-[9px] uppercase tracking-widest text-[var(--color-on-surface-variant)]">Revisión</p>
                    <p class="font-bold text-[var(--color-on-surface)] text-sm">{quoteTracking.fechaRevision.toLocaleDateString("es-AR")}</p>
                  </div>
                </div>
              )}
              {quoteTracking.fechaAprobacion && (
                <div class="flex items-center gap-3">
                  <span class="material-symbols-outlined text-base text-emerald-400 opacity-70">check_circle</span>
                  <div>
                    <p class="text-[9px] uppercase tracking-widest text-[var(--color-on-surface-variant)]">Aprobada</p>
                    <p class="font-bold text-[var(--color-on-surface)] text-sm">{quoteTracking.fechaAprobacion.toLocaleDateString("es-AR")}</p>
                  </div>
                </div>
              )}
              <div class="flex items-center gap-3">
                <span class={`material-symbols-outlined text-base opacity-70 ${diasVenc < 0 ? 'text-red-400' : diasVenc <= 3 ? 'text-orange-400' : 'text-[var(--color-primary)]'}`}>schedule</span>
                <div>
                  <p class="text-[9px] uppercase tracking-widest text-[var(--color-on-surface-variant)]">Vencimiento</p>
                  <div class="flex items-center gap-2">
                    <p class="font-bold text-[var(--color-on-surface)] text-sm">{quoteTracking.fechaVencimiento.toLocaleDateString("es-AR")}</p>
                    <span class={`px-2 py-0.5 text-[9px] font-black uppercase rounded-full ${diasVenc < 0 ? 'bg-red-500/10 text-red-400 border border-red-500/20' : diasVenc <= 3 ? 'bg-orange-500/10 text-orange-400 border border-orange-500/20' : 'bg-[var(--color-primary)]/10 text-[var(--color-primary)] border border-[var(--color-primary)]/20'}`}>
                      {diasVenc < 0 ? "Vencida" : `${diasVenc}d`}
                    </span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Recordatorio programado -->
          <div class="bg-[var(--color-surface-container-low)] rounded-xl border border-[var(--color-outline-variant)]/50 shadow-[0_12px_32px_rgba(0,0,0,0.3)] overflow-hidden">
            <div class="px-5 py-4 border-b border-[var(--color-outline-variant)]/40 flex items-center justify-between gap-2">
              <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-lg text-amber-400">alarm</span>
                <h3 class="font-black text-[var(--color-on-surface)] uppercase tracking-widest text-xs">Recordatorio</h3>
              </div>
              <div class="flex items-center gap-1">
                <button
                  onclick="checkRemindersNow()"
                  class="p-1.5 rounded-lg text-[var(--color-on-surface-variant)] hover:text-[var(--color-primary)] hover:bg-[var(--color-primary)]/10 transition-all"
                  title="Verificar ahora"
                >
                  <span class="material-symbols-outlined text-base">refresh</span>
                </button>
                <button
                  onclick="showReminderModal()"
                  class="flex items-center gap-1.5 px-3 py-1.5 rounded-xl text-xs font-bold bg-gradient-to-br from-amber-500 to-amber-600 text-white shadow-[0_4px_12px_rgba(245,158,11,0.3)] hover:scale-[1.02] transition-all"
                >
                  <span class="material-symbols-outlined text-sm">add_alarm</span>
                  Programar
                </button>
              </div>
            </div>

            <div class="p-5">
              {quoteTracking.proximoSeguimiento ? (
                <div class="space-y-3">
                  <div class="flex items-start justify-between gap-3">
                    <div class="flex-1 space-y-2">
                      <div class="flex items-center gap-2">
                        <span class="material-symbols-outlined text-sm text-amber-400">alarm_on</span>
                        <p class="text-xs font-bold text-[var(--color-on-surface)]">{formatArgentinaDateTime(quoteTracking.proximoSeguimiento)}</p>
                      </div>
                      {quoteTracking.proximoSeguimientoTipo && (
                        <span class="inline-block px-2 py-0.5 text-[9px] font-black uppercase tracking-widest rounded-full border bg-amber-500/10 text-amber-400 border-amber-500/20">
                          {quoteTracking.proximoSeguimientoTipo === "seguimiento" ? "Seguimiento" :
                           quoteTracking.proximoSeguimientoTipo === "vencimiento" ? "Vencimiento" : "Revisión"}
                        </span>
                      )}
                      {quoteTracking.proximoSeguimientoMensaje && (
                        <p class="text-xs text-[var(--color-on-surface-variant)] leading-relaxed">{quoteTracking.proximoSeguimientoMensaje}</p>
                      )}
                      <div class="flex items-center gap-3 text-[10px] text-[var(--color-on-surface-variant)]">
                        <span>{quoteTracking.proximoSeguimientoEmail ? "📧 Email" : "Sin email"}</span>
                        <span>{quoteTracking.proximoSeguimientoPush ? "🔔 Push" : "Sin push"}</span>
                      </div>
                      <div class="text-xs font-bold text-amber-400">
                        {(() => {
                          const ahora = new Date();
                          const seg = new Date(quoteTracking.proximoSeguimiento);
                          const h = Math.ceil((seg.getTime() - ahora.getTime()) / (1000 * 60 * 60));
                          if (h > 0) return `⏳ En ${h} hora${h !== 1 ? "s" : ""}`;
                          if (h === 0) return "🚨 ¡Ahora!";
                          return `⏰ Hace ${Math.abs(h)} hora${Math.abs(h) !== 1 ? "s" : ""}`;
                        })()}
                      </div>
                    </div>
                    <button
                      onclick={`deleteReminder('${quoteTracking.id}')`}
                      class="p-2 rounded-xl text-[var(--color-on-surface-variant)] hover:text-red-400 hover:bg-red-500/10 transition-all shrink-0"
                      title="Eliminar recordatorio"
                    >
                      <span class="material-symbols-outlined text-xl">delete</span>
                    </button>
                  </div>
                </div>
              ) : (
                <div class="text-center py-6">
                  <span class="material-symbols-outlined text-4xl opacity-30 text-[var(--color-on-surface-variant)] block mb-2">alarm_off</span>
                  <p class="text-xs text-[var(--color-on-surface-variant)]">No hay recordatorios programados.</p>
                </div>
              )}
            </div>
          </div>


        </div>
      </div>
    )}
  </div>

  <!-- ── Modal Cambiar Estado ──────────────────────────────────────────────── -->
  <div id="status-modal" class="fixed inset-0 bg-black/60 backdrop-blur-sm hidden z-50 flex items-center justify-center p-4">
    <div class="bg-[var(--color-surface-container)] border border-[var(--color-outline-variant)] rounded-2xl shadow-[0_32px_64px_rgba(0,0,0,0.6)] w-full max-w-md">
      <div class="flex items-center justify-between px-6 py-5 border-b border-[var(--color-outline-variant)]/40">
        <div class="flex items-center gap-3">
          <span class="material-symbols-outlined text-xl text-[var(--color-primary)]">swap_horiz</span>
          <h3 class="text-base font-black text-[var(--color-on-surface)]">Cambiar Estado</h3>
        </div>
        <button onclick="hideStatusModal()" class="p-2 rounded-xl text-[var(--color-on-surface-variant)] hover:bg-[var(--color-surface-container-high)] transition-all">
          <span class="material-symbols-outlined">close</span>
        </button>
      </div>
      <form id="status-form" class="p-6 space-y-5">
        <div>
          <label class="block text-[10px] font-black uppercase tracking-widest text-[var(--color-on-surface-variant)] mb-2">Comentario (opcional)</label>
          <textarea
            id="status-comment"
            rows="3"
            class="w-full px-4 py-3 bg-[var(--color-surface-container-high)] border border-[var(--color-outline-variant)] rounded-xl text-sm text-[var(--color-on-surface)] placeholder-[var(--color-on-surface-variant)] focus:outline-none focus:border-[var(--color-primary)] transition-colors resize-none"
            placeholder="Agrega un comentario sobre este cambio..."
          ></textarea>
        </div>
        <div class="flex justify-end gap-3">
          <button type="button" onclick="hideStatusModal()" class="px-5 py-2.5 rounded-xl font-bold text-sm border border-[var(--color-outline-variant)] text-[var(--color-on-surface)] hover:bg-[var(--color-surface-container-high)] transition-all">
            Cancelar
          </button>
          <button type="submit" class="px-5 py-2.5 rounded-xl font-bold text-sm bg-gradient-to-br from-blue-500 to-blue-700 text-white shadow-[0_4px_12px_rgba(59,130,246,0.3)] hover:scale-[1.02] transition-all">
            Confirmar cambio
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- ── Modal Recordatorio ────────────────────────────────────────────────── -->
  <div id="reminder-modal" class="fixed inset-0 bg-black/60 backdrop-blur-sm hidden z-50 flex items-center justify-center p-4">
    <div class="bg-[var(--color-surface-container)] border border-[var(--color-outline-variant)] rounded-2xl shadow-[0_32px_64px_rgba(0,0,0,0.6)] w-full max-w-md">
      <div class="flex items-center justify-between px-6 py-5 border-b border-[var(--color-outline-variant)]/40">
        <div class="flex items-center gap-3">
          <span class="material-symbols-outlined text-xl text-amber-400">add_alarm</span>
          <h3 class="text-base font-black text-[var(--color-on-surface)]">Programar Recordatorio</h3>
        </div>
        <button onclick="hideReminderModal()" class="p-2 rounded-xl text-[var(--color-on-surface-variant)] hover:bg-[var(--color-surface-container-high)] transition-all">
          <span class="material-symbols-outlined">close</span>
        </button>
      </div>
      <form id="reminder-form" class="p-6 space-y-5">
        <div>
          <label class="block text-[10px] font-black uppercase tracking-widest text-[var(--color-on-surface-variant)] mb-2">Tipo de Recordatorio</label>
          <select id="reminder-type" class="w-full px-4 py-3 bg-[var(--color-surface-container-high)] border border-[var(--color-outline-variant)] rounded-xl text-sm text-[var(--color-on-surface)] focus:outline-none focus:border-[var(--color-primary)] transition-colors">
            <option value="seguimiento">Seguimiento</option>
            <option value="vencimiento">Vencimiento</option>
            <option value="revision">Revisión</option>
          </select>
        </div>
        <div>
          <label class="block text-[10px] font-black uppercase tracking-widest text-[var(--color-on-surface-variant)] mb-2">Fecha del Recordatorio</label>
          <input
            type="datetime-local"
            id="reminder-date"
            class="w-full px-4 py-3 bg-[var(--color-surface-container-high)] border border-[var(--color-outline-variant)] rounded-xl text-sm text-[var(--color-on-surface)] focus:outline-none focus:border-[var(--color-primary)] transition-colors"
            required
          />
        </div>
        <div>
          <label class="block text-[10px] font-black uppercase tracking-widest text-[var(--color-on-surface-variant)] mb-2">Mensaje</label>
          <textarea
            id="reminder-message"
            rows="3"
            class="w-full px-4 py-3 bg-[var(--color-surface-container-high)] border border-[var(--color-outline-variant)] rounded-xl text-sm text-[var(--color-on-surface)] placeholder-[var(--color-on-surface-variant)] focus:outline-none focus:border-[var(--color-primary)] transition-colors resize-none"
            placeholder="Ej: Hacer seguimiento con el cliente..."
            required
          ></textarea>
        </div>
        <div class="space-y-3">
          <label class="flex items-center gap-3 cursor-pointer">
            <input type="checkbox" id="send-email" class="w-4 h-4 accent-[var(--color-primary)] rounded" />
            <div>
              <p class="text-sm font-bold text-[var(--color-on-surface)]">Notificar por email</p>
              <p class="text-[10px] text-[var(--color-on-surface-variant)]">Recibirás un email a la hora programada</p>
            </div>
          </label>

          <div id="recipients-section" class="hidden ml-7">
            <label class="block text-[10px] font-black uppercase tracking-widest text-[var(--color-on-surface-variant)] mb-2">Destinatarios</label>
            <div id="recipients-list" class="space-y-2 max-h-32 overflow-y-auto bg-[var(--color-surface-container-high)] border border-[var(--color-outline-variant)] rounded-xl p-3"></div>
            <div class="flex gap-3 mt-2">
              <button type="button" id="select-all-recipients" class="text-[10px] font-bold text-[var(--color-primary)] hover:underline">Seleccionar todos</button>
              <button type="button" id="deselect-all-recipients" class="text-[10px] font-bold text-[var(--color-on-surface-variant)] hover:underline">Deseleccionar todos</button>
            </div>
          </div>

          <label class="flex items-center gap-3 cursor-pointer">
            <input type="checkbox" id="send-push" class="w-4 h-4 accent-[var(--color-primary)] rounded" checked />
            <div>
              <p class="text-sm font-bold text-[var(--color-on-surface)]">Notificación en pantalla</p>
              <p class="text-[10px] text-[var(--color-on-surface-variant)]">Aparecerá cuando estés en la app</p>
            </div>
          </label>
        </div>

        <div class="flex justify-end gap-3 pt-2">
          <button type="button" onclick="hideReminderModal()" class="px-5 py-2.5 rounded-xl font-bold text-sm border border-[var(--color-outline-variant)] text-[var(--color-on-surface)] hover:bg-[var(--color-surface-container-high)] transition-all">
            Cancelar
          </button>
          <button type="submit" class="px-5 py-2.5 rounded-xl font-bold text-sm bg-gradient-to-br from-amber-500 to-amber-600 text-white shadow-[0_4px_12px_rgba(245,158,11,0.3)] hover:scale-[1.02] transition-all">
            Programar
          </button>
        </div>
      </form>
    </div>
  </div>
</Dashboard>

<script is:inline>
  let currentStatus = '';
  let currentQuoteId = '';
  let currentUserEmail = 'russofg@gmail.com';
  let availableUsers = [];

  function changeStatus(status, quoteId) {
    currentStatus = status;
    currentQuoteId = quoteId;
    const modal = document.getElementById('status-modal');
    if (modal) { modal.classList.remove('hidden'); modal.classList.add('flex'); }
  }

  function hideStatusModal() {
    const modal = document.getElementById('status-modal');
    const comment = document.getElementById('status-comment');
    if (modal) { modal.classList.add('hidden'); modal.classList.remove('flex'); }
    if (comment) comment.value = '';
  }

  function showReminderModal() {
    const modal = document.getElementById('reminder-modal');
    if (modal) { modal.classList.remove('hidden'); modal.classList.add('flex'); }
  }

  function hideReminderModal() {
    const modal = document.getElementById('reminder-modal');
    const form = document.getElementById('reminder-form');
    if (modal) { modal.classList.add('hidden'); modal.classList.remove('flex'); }
    if (form) form.reset();
  }

  function testNotification() {
    const mensaje = `Seguimiento pendiente: COT-1759102172719 (Candela) - ¡Ya es hora!`;
    if (window.showNotification) {
      window.showNotification(mensaje, 'warning');
    } else {
      alert('Notificación de prueba: ' + mensaje);
    }
    if (window.showPushNotification) {
      window.showPushNotification('Seguimiento Pendiente', mensaje);
    }
  }

  async function checkRemindersNow() {
    try {
      if (window.notificationSystem) {
        await window.notificationSystem.checkPendingReminders();
      } else {
        const response = await fetch('/api/quote-tracking?action=stats');
        if (response.ok) {
          const stats = await response.json();
          if (stats.seguimientosPendientes && stats.seguimientosPendientes.length > 0) {
            const seguimiento = stats.seguimientosPendientes[0];
            const fechaSeguimiento = new Date(seguimiento.proximoSeguimiento);
            const ahora = new Date();
            const horasRestantes = Math.ceil((fechaSeguimiento.getTime() - ahora.getTime()) / (1000 * 60 * 60));
            let mensaje = `Seguimiento pendiente: ${seguimiento.numero} (${seguimiento.clienteNombre})`;
            mensaje += horasRestantes > 0 ? ` - En ${horasRestantes}h` : ' - ¡Ya es hora!';
            if (window.showNotification) window.showNotification(mensaje, 'warning');
            else alert('Verificación manual: ' + mensaje);
          } else {
            if (window.showNotification) window.showNotification('No hay seguimientos pendientes', 'info');
            else alert('No hay seguimientos pendientes');
          }
        }
      }
    } catch (error) {
      console.error('Error checking reminders:', error);
      alert('Error al verificar recordatorios');
    }
  }

  async function deleteReminder(quoteId) {
    if (!confirm('¿Estás seguro de que querés eliminar este recordatorio?')) return;
    try {
      const response = await fetch('/api/quote-tracking', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'delete-reminder', quoteId })
      });
      if (response.ok) {
        if (window.showNotification) window.showNotification('Recordatorio eliminado correctamente', 'success');
        else alert('Recordatorio eliminado correctamente');
        setTimeout(() => location.reload(), 1000);
      } else {
        const error = await response.json();
        if (window.showNotification) window.showNotification('Error: ' + error.error, 'error');
        else alert('Error: ' + error.error);
      }
    } catch (error) {
      console.error('Error deleting reminder:', error);
      if (window.showNotification) window.showNotification('Error al eliminar el recordatorio', 'error');
      else alert('Error al eliminar el recordatorio');
    }
  }

  async function testCompleteFlow() {
    try {
      const testDate = new Date();
      testDate.setMinutes(testDate.getMinutes() + 5);
      const currentQuoteId = window.location.pathname.split('/').pop();
      const response = await fetch('/api/quote-tracking', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          action: 'schedule-reminder',
          quoteId: currentQuoteId,
          tipo: 'seguimiento',
          fecha: testDate.toISOString(),
          mensaje: 'Recordatorio de prueba - Flujo completo',
          sendEmail: false,
          sendPush: true,
          userEmail: currentUserEmail
        })
      });
      if (response.ok) {
        if (window.showNotification) window.showNotification('✅ Paso 1: Recordatorio programado', 'success');
        setTimeout(async () => {
          try {
            const checkResponse = await fetch('/api/quote-tracking?action=stats');
            if (checkResponse.ok) {
              const stats = await checkResponse.json();
              if (stats.seguimientosPendientes && stats.seguimientosPendientes.length > 0) {
                if (window.showNotification) window.showNotification('✅ Paso 2: Seguimiento detectado', 'success');
                setTimeout(() => {
                  if (window.showNotification) window.showNotification('🎉 Flujo completo probado exitosamente', 'success');
                }, 1000);
              } else {
                if (window.showNotification) window.showNotification('⚠️ Paso 2: No se detectó seguimiento', 'warning');
              }
            }
          } catch (error) { console.error('Error in test flow:', error); }
        }, 2000);
      } else {
        const error = await response.json();
        if (window.showNotification) window.showNotification('❌ Error: ' + error.error, 'error');
      }
    } catch (error) {
      console.error('Error testing complete flow:', error);
      if (window.showNotification) window.showNotification('❌ Error al probar flujo completo', 'error');
    }
  }

  document.addEventListener('DOMContentLoaded', function() {
    const statusForm = document.getElementById('status-form');
    if (statusForm) {
      statusForm.addEventListener('submit', async function(e) {
        e.preventDefault();
        const comment = document.getElementById('status-comment');
        const commentValue = comment ? comment.value : '';
        try {
          const response = await fetch('/api/quote-tracking', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              action: 'update-status',
              quoteId: currentQuoteId,
              status: currentStatus,
              comentario: commentValue,
              usuario: 'Usuario Actual'
            })
          });
          if (response.ok) { hideStatusModal(); location.reload(); }
          else { const error = await response.json(); alert('Error: ' + error.error); }
        } catch (error) {
          console.error('Error updating status:', error);
          alert('Error al actualizar el estado');
        }
      });
    }

    const reminderForm = document.getElementById('reminder-form');
    if (reminderForm) {
      reminderForm.addEventListener('submit', async function(e) {
        e.preventDefault();
        const tipo = document.getElementById('reminder-type');
        const fecha = document.getElementById('reminder-date');
        const mensaje = document.getElementById('reminder-message');
        const sendEmail = document.getElementById('send-email');
        const sendPush = document.getElementById('send-push');
        const tipoValue = tipo ? tipo.value : '';
        const fechaValue = fecha ? fecha.value : '';
        const mensajeValue = mensaje ? mensaje.value : '';
        const sendEmailValue = sendEmail ? sendEmail.checked : false;
        const sendPushValue = sendPush ? sendPush.checked : true;
        const fechaIsoValue = fechaValue ? new Date(fechaValue).toISOString() : '';
        if (fechaValue && Number.isNaN(new Date(fechaValue).getTime())) {
          if (window.showNotification) window.showNotification('La fecha del recordatorio no es válida', 'error');
          else alert('La fecha del recordatorio no es válida');
          return;
        }
        let selectedRecipients = [];
        if (sendEmailValue) { selectedRecipients = getSelectedRecipients(); }
        const currentQuoteId = window.location.pathname.split('/').pop();
        try {
          const response = await fetch('/api/quote-tracking', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              action: 'schedule-reminder',
              quoteId: currentQuoteId,
              tipo: tipoValue,
              fecha: fechaIsoValue,
              mensaje: mensajeValue,
              sendEmail: sendEmailValue,
              sendPush: sendPushValue,
              userEmail: currentUserEmail,
              recipients: selectedRecipients
            })
          });
          if (response.ok) {
            hideReminderModal();
            if (window.showNotification) window.showNotification('Recordatorio programado. Se enviará un email a la hora programada.', 'success');
            else alert('Recordatorio programado correctamente.');
            setTimeout(() => location.reload(), 1000);
          } else {
            const error = await response.json();
            if (window.showNotification) window.showNotification('Error: ' + error.error, 'error');
            else alert('Error: ' + error.error);
          }
        } catch (error) {
          console.error('Error scheduling reminder:', error);
          if (window.showNotification) window.showNotification('Error al programar el recordatorio', 'error');
          else alert('Error al programar el recordatorio');
        }
      });
    }

    const sendEmailCheckbox = document.getElementById('send-email');
    const recipientsSection = document.getElementById('recipients-section');
    if (sendEmailCheckbox && recipientsSection) {
      sendEmailCheckbox.addEventListener('change', function() {
        if (this.checked) { recipientsSection.classList.remove('hidden'); loadAvailableUsers(); }
        else { recipientsSection.classList.add('hidden'); }
      });
    }

    document.getElementById('select-all-recipients')?.addEventListener('click', selectAllRecipients);
    document.getElementById('deselect-all-recipients')?.addEventListener('click', deselectAllRecipients);

    document.getElementById('status-modal')?.addEventListener('click', function(e) {
      if (e.target === this) hideStatusModal();
    });
    document.getElementById('reminder-modal')?.addEventListener('click', function(e) {
      if (e.target === this) hideReminderModal();
    });

    async function loadAvailableUsers() {
      try {
        const response = await fetch('/api/users');
        const data = await response.json();
        if (data.success) { availableUsers = data.usuarios; renderRecipientsList(); }
        else { availableUsers = []; }
      } catch (error) { availableUsers = []; }
    }

    function renderRecipientsList() {
      const recipientsList = document.getElementById('recipients-list');
      if (!recipientsList) return;
      recipientsList.innerHTML = '';
      if (availableUsers.length === 0) {
        recipientsList.innerHTML = '<p class="text-[var(--color-on-surface-variant)] text-xs">No hay usuarios disponibles</p>';
        return;
      }
      availableUsers.forEach(user => {
        const userDiv = document.createElement('div');
        userDiv.className = 'flex items-center gap-2';
        userDiv.innerHTML = `
          <input type="checkbox" id="recipient-${user.id}" value="${user.email}" class="w-4 h-4 accent-[var(--color-primary)] rounded" checked />
          <label for="recipient-${user.id}" class="text-xs text-[var(--color-on-surface)] cursor-pointer">
            <span class="font-bold">${user.nombre}</span>
            <span class="text-[var(--color-on-surface-variant)]"> (${user.email})</span>
          </label>
        `;
        recipientsList.appendChild(userDiv);
      });
    }

    function selectAllRecipients() {
      document.querySelectorAll('#recipients-list input[type="checkbox"]').forEach(cb => cb.checked = true);
    }
    function deselectAllRecipients() {
      document.querySelectorAll('#recipients-list input[type="checkbox"]').forEach(cb => cb.checked = false);
    }
    function getSelectedRecipients() {
      return Array.from(document.querySelectorAll('#recipients-list input[type="checkbox"]:checked')).map(cb => cb.value);
    }
  });
</script>
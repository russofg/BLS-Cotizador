---
import DashboardLayout from "../layouts/Dashboard.astro";
import ScrollbarStyles from "../components/ScrollbarStyles.astro";
import { DateHelper } from "../utils/dateHelpers";
import { QuoteHelper } from "../utils/quoteHelpers";

// Load analytics data
let analytics: any = null;
let stats: {
  totalCotizaciones: number;
  cotizacionesPendientes: number;
  itemsActivos: number;
  totalClientes: number;
  cotizacionesRecientes: any[];
} = {
  totalCotizaciones: 0,
  cotizacionesPendientes: 0,
  itemsActivos: 0,
  totalClientes: 0,
  cotizacionesRecientes: [],
};

// Try to load analytics and stats, but fail gracefully
try {
  const { AnalyticsService } = await import("../services/AnalyticsService");
  analytics = await AnalyticsService.getDashboardAnalytics();
  
  // Update stats with analytics data
  stats = {
    totalCotizaciones: analytics.quotes.totalQuotes,
    cotizacionesPendientes: analytics.quotes.quotesByStatus.find((s: any) => s.status === 'Pendiente')?.count || 0,
    itemsActivos: analytics.items.activeItems,
    totalClientes: analytics.clients.totalClients,
    cotizacionesRecientes: analytics.recentQuotes || [],
  };
} catch (error) {
  try {
    const { statsService } = await import("../utils/database");
    stats = await statsService.getDashboardStats();
  } catch (fallbackError) {
    // Keep default stats
  }
}
---

<DashboardLayout title="Dashboard - BLS Cotizador" activeSection="dashboard">
  <ScrollbarStyles />
  
  <div class="p-4 sm:p-12 space-y-10 w-full max-w-full">
    
    <!-- Header Section -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-end gap-6 sm:gap-0">
      <div class="space-y-1">
        <h2 class="text-3xl sm:text-[2.75rem] font-bold tracking-tight text-white leading-none">Dashboard del Sistema</h2>
        <p class="text-gray-400 font-medium">Rendimiento de operaciones globales e información en tiempo real.</p>
      </div>
      <div class="flex gap-4 w-full sm:w-auto">
        <button class="px-6 py-2.5 rounded-lg text-sm font-semibold bg-surface-container text-gray-300 hover:bg-surface-container-low transition-colors border border-outline-variant/15 flex-1 sm:flex-none text-center shadow-premium">
          Exportar Reporte
        </button>
        <button class="px-6 py-2.5 rounded-lg text-sm font-semibold bg-gradient-to-br from-primary-500 to-primary-600 text-white shadow-premium flex-1 sm:flex-none text-center hover:scale-[1.02] transition-transform">
          Actualizar Datos
        </button>
      </div>
    </div>

    <!-- Bento Summary Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6">
      
      <!-- Summary Card 1 -->
      <div class="bg-surface-container-lowest p-8 rounded-xl border border-outline-variant/10 shadow-[0_12px_32px_rgba(0,0,0,0.4)] transition-transform hover:scale-[1.01]">
        <div class="flex justify-between items-start">
          <p class="text-[0.75rem] uppercase tracking-widest text-gray-400 font-bold">Cotizaciones Totales</p>
          <span class="material-symbols-outlined text-primary-500 select-none">description</span>
        </div>
        <div class="mt-4">
          <span class="text-4xl font-black text-white tracking-tighter">{stats.totalCotizaciones}</span>
          <div class="mt-2 flex items-center gap-1 text-[10px] font-bold text-green-400 bg-green-500/10 px-2 py-0.5 rounded w-fit">
            <span class="material-symbols-outlined text-[12px] select-none">trending_up</span>
            <span>+0% VS MES ANTERIOR</span>
          </div>
        </div>
      </div>

      <!-- Summary Card 2 -->
      <div class="bg-surface-container-lowest p-8 rounded-xl border border-outline-variant/10 shadow-[0_12px_32px_rgba(0,0,0,0.4)] transition-transform hover:scale-[1.01]">
        <div class="flex justify-between items-start">
          <p class="text-[0.75rem] uppercase tracking-widest text-gray-400 font-bold">Pendientes</p>
          <span class="material-symbols-outlined text-amber-500 select-none">pending_actions</span>
        </div>
        <div class="mt-4">
          <span class="text-4xl font-black text-white tracking-tighter">{stats.cotizacionesPendientes}</span>
          <p class="text-xs text-gray-500 mt-2">Acción requerida pronto</p>
        </div>
      </div>

      <!-- Summary Card 3 -->
      <div class="bg-surface-container-lowest p-8 rounded-xl border border-outline-variant/10 shadow-[0_12px_32px_rgba(0,0,0,0.4)] transition-transform hover:scale-[1.01]">
        <div class="flex justify-between items-start">
          <p class="text-[0.75rem] uppercase tracking-widest text-gray-400 font-bold">Ítems Activos</p>
          <span class="material-symbols-outlined text-green-500 select-none">inventory</span>
        </div>
        <div class="mt-4">
          <span class="text-4xl font-black text-white tracking-tighter">{stats.itemsActivos}</span>
          <p class="text-xs text-gray-500 mt-2 font-medium">En catálogo general</p>
        </div>
      </div>

      <!-- Summary Card 4 -->
      <div class="bg-surface-container-lowest p-8 rounded-xl border border-outline-variant/10 shadow-[0_12px_32px_rgba(0,0,0,0.4)] transition-transform hover:scale-[1.01]">
        <div class="flex justify-between items-start">
          <p class="text-[0.75rem] uppercase tracking-widest text-gray-400 font-bold">Clientes Totales</p>
          <span class="material-symbols-outlined text-purple-500 select-none">groups_2</span>
        </div>
        <div class="mt-4">
          <span class="text-4xl font-black text-white tracking-tighter">{stats.totalClientes}</span>
          <div class="mt-2 flex items-center gap-1 text-[10px] font-bold text-primary-400 bg-primary-500/10 px-2 py-0.5 rounded w-fit">
            <span class="material-symbols-outlined text-[12px] select-none">trending_up</span>
            <span>+2 NUEVOS ESTA SEMANA</span>
          </div>
        </div>
      </div>

    </div>

    <!-- Analysis & Charts Section -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      
      <!-- Large Chart: Rendimiento de Cotizaciones -->
      <div class="lg:col-span-2 bg-surface-container-lowest rounded-xl border border-outline-variant/10 shadow-[0_12px_32px_rgba(0,0,0,0.4)] p-8 space-y-6">
        <div class="flex justify-between items-center">
          <h3 class="text-xl font-bold tracking-tight text-white">Rendimiento de Cotizaciones</h3>
          <div class="flex gap-2">
            <span class="inline-flex items-center px-3 py-1 rounded-full bg-surface-container text-[10px] font-bold text-gray-400">6 MESES</span>
          </div>
        </div>
        
        {analytics ? (
          <div class="space-y-4">
            <div class="h-64 flex items-end justify-between gap-4 px-4 w-full">
              {analytics.quotes.quotesByMonth.slice(-6).map((month: any, idx: number) => {
                const maxCount = Math.max(...analytics.quotes.quotesByMonth.map((m: any) => m.count));
                const percentage = Math.max(10, Math.floor((month.count / maxCount) * 100));
                
                return (
                  <div class={`w-full ${idx === analytics.quotes.quotesByMonth.slice(-6).length - 1 ? 'bg-primary-500' : 'bg-surface-container hover:bg-primary-600'} rounded-t-sm transition-colors cursor-pointer relative group`} style={`height: ${percentage}%`}>
                    <div class={`absolute -top-10 left-1/2 -translate-x-1/2 bg-white text-gray-900 text-[10px] px-2 py-1 rounded transition-opacity ${idx === analytics.quotes.quotesByMonth.slice(-6).length - 1 ? 'opacity-100' : 'opacity-0 group-hover:opacity-100'}`}>
                      {month.count}
                    </div>
                  </div>
                );
              })}
            </div>
            <div class="flex justify-between text-[10px] text-gray-500 font-bold tracking-widest px-4">
              {analytics.quotes.quotesByMonth.slice(-6).map((month: any) => (
                <span class="uppercase">
                  {new Date(month.month + '-01').toLocaleDateString('es-ES', { month: 'short' }).substring(0, 3)}
                </span>
              ))}
            </div>
          </div>
        ) : (
          <div class="h-64 flex items-center justify-center border-2 border-dashed border-outline-variant/20 rounded-xl">
            <p class="text-gray-500 text-sm">Gargando métricas...</p>
          </div>
        )}
      </div>

      <!-- Secondary Analysis: Distribución -->
      <div class="bg-surface-container-lowest rounded-xl border border-outline-variant/10 shadow-[0_12px_32px_rgba(0,0,0,0.4)] p-8 flex flex-col justify-between">
        <div class="space-y-8">
          <h3 class="text-xl font-bold tracking-tight text-white">¿Qué ofrecemos? (por categoría)</h3>
          <div class="space-y-6">
            
            {analytics ? (() => {
              const totalItemsCount = analytics.items.itemsByCategory.reduce((acc: number, c: any) => acc + c.count, 0);
              const topCategories = analytics.items.itemsByCategory.slice(0, 4);
              const colors = ['bg-primary-500', 'bg-primary-400', 'bg-gray-500', 'bg-gray-600'];
              
              return topCategories.map((category: any, idx: number) => {
                const percentage = totalItemsCount > 0 ? Math.round((category.count / totalItemsCount) * 100) : 0;
                
                return (
                  <div class="space-y-2">
                    <div class="flex justify-between text-xs font-bold uppercase tracking-wider">
                      <span class="text-gray-400 truncate pr-4">{category.category}</span>
                      <span class="text-white">{percentage}%</span>
                    </div>
                    <div class="h-1.5 w-full bg-surface-container rounded-full overflow-hidden">
                      <div class={`h-full ${colors[idx % 4]} rounded-full shadow-premium`} style={`width: ${percentage}%`}></div>
                    </div>
                  </div>
                );
              });
            })() : (
              <p class="text-gray-500 text-xs">Cargando...</p>
            )}

          </div>
        </div>
        <a href="/items" class="w-full mt-8 py-3 rounded-lg text-xs font-bold text-primary-400 hover:bg-primary-500/10 transition-colors border border-primary-500/20 text-center block">
          Reporte Detallado de Ítems
        </a>
      </div>

    </div>

    <!-- Bottom Content Section -->
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
      
      <!-- Recent Quotations List -->
      <div class="lg:col-span-3 bg-surface-container-lowest rounded-xl border border-outline-variant/10 shadow-[0_12px_32px_rgba(0,0,0,0.4)] overflow-hidden">
        <div class="px-8 py-6 border-b border-surface-container flex justify-between items-center">
          <h3 class="text-xl font-bold tracking-tight text-white">Cotizaciones Recientes</h3>
          <a class="text-xs font-bold text-primary-400 flex items-center gap-1 hover:underline" href="/quotes">
            VER TODO <span class="material-symbols-outlined text-sm select-none">chevron_right</span>
          </a>
        </div>
        
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead>
              <tr class="text-left bg-surface-container/30">
                <th class="px-8 py-4 text-[10px] font-black text-gray-500 uppercase tracking-[0.1em]">ID Cotización</th>
                <th class="px-8 py-4 text-[10px] font-black text-gray-500 uppercase tracking-[0.1em]">Nombre del Cliente</th>
                <th class="px-8 py-4 text-[10px] font-black text-gray-500 uppercase tracking-[0.1em]">Fecha de Creación</th>
                <th class="px-8 py-4 text-[10px] font-black text-gray-500 uppercase tracking-[0.1em]">Valor Total</th>
                <th class="px-8 py-4 text-[10px] font-black text-gray-500 uppercase tracking-[0.1em]">Estado</th>
                <th class="px-8 py-4"></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-surface-container">
              {stats.cotizacionesRecientes.length > 0 ? stats.cotizacionesRecientes.slice(0, 5).map((cotizacion: any) => {
                const normStatus = QuoteHelper.normalizeQuoteStatus(cotizacion.estado);
                let statusBadge = "bg-gray-500/10 text-gray-400 border-gray-500/20";
                let statusText = "Borrador";
                
                if (normStatus === 'aprobada') {
                  statusBadge = "bg-green-500/10 text-green-400 border-green-500/20";
                  statusText = "Aprobada";
                } else if (normStatus === 'enviada') {
                  statusBadge = "bg-primary-500/10 text-primary-400 border-primary-500/20";
                  statusText = "Enviada";
                } else if (normStatus === 'rechazada') {
                  statusBadge = "bg-red-500/10 text-red-400 border-red-500/20";
                  statusText = "Rechazada";
                } else if (normStatus === 'pendiente') {
                  statusBadge = "bg-amber-500/10 text-amber-400 border-amber-500/20";
                  statusText = "Pendiente";
                } else if (normStatus === 'convertida') {
                  statusBadge = "bg-violet-500/10 text-violet-400 border-violet-500/20";
                  statusText = "Facturada";
                }
                
                return (
                  <tr class="hover:bg-surface-container/50 transition-colors">
                    <td class="px-8 py-5 font-medium text-white">
                      <a href={`/quotes/view/${cotizacion.id}`} class="hover:text-primary-400 transition-colors">
                        {QuoteHelper.getDisplayQuoteNumber(cotizacion)}
                      </a>
                    </td>
                    <td class="px-8 py-5">
                      <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded bg-surface-container flex items-center justify-center text-xs font-bold text-gray-400">
                          {cotizacion.cliente?.nombre?.substring(0, 2).toUpperCase() || "CL"}
                        </div>
                        <span class="font-semibold text-gray-300">{cotizacion.cliente?.nombre || "Cliente General"}</span>
                      </div>
                    </td>
                    <td class="px-8 py-5 text-sm text-gray-500">
                      {new Date(cotizacion.fechaEmision || cotizacion.createdAt).toLocaleDateString("es-AR")}
                    </td>
                    <td class="px-8 py-5 font-bold text-white">
                      \${cotizacion.total.toLocaleString("es-AR")}
                    </td>
                    <td class="px-8 py-5">
                      <span class={`px-3 py-1 border rounded-full text-[10px] font-bold uppercase ${statusBadge}`}>
                        {statusText}
                      </span>
                    </td>
                    <td class="px-8 py-5">
                      <a href={`/quotes/view/${cotizacion.id}`} class="text-gray-500 hover:text-primary-400 transition-colors inline-block">
                        <span class="material-symbols-outlined select-none block">more_vert</span>
                      </a>
                    </td>
                  </tr>
                );
              }) : (
                <tr class="hover:bg-surface-container/50 transition-colors">
                  <td class="px-8 py-5 font-medium text-gray-500 italic">No hay cotizaciones</td>
                  <td class="px-8 py-5 text-gray-600 text-sm" colspan="5">Sistema sincronizado, genera tu primera cotización.</td>
                </tr>
              )}
            </tbody>
          </table>
        </div>
      </div>

      <!-- Quick Actions Pillar -->
      <div class="space-y-6">
        <div class="bg-surface-container-lowest rounded-xl border border-outline-variant/10 shadow-[0_12px_32px_rgba(0,0,0,0.4)] p-8 space-y-6">
          <h3 class="text-xl font-bold tracking-tight text-white">Acciones Rápidas</h3>
          <div class="grid grid-cols-1 gap-4">
            <a href="/clients" class="flex items-center justify-between p-4 rounded-lg bg-surface-container/50 hover:bg-primary-600 group transition-all duration-300 cursor-pointer border border-transparent hover:border-primary-500/30">
              <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-primary-500 group-hover:text-white select-none">person_add</span>
                <span class="text-sm font-semibold text-gray-300 group-hover:text-white">Agregar Cliente</span>
              </div>
              <span class="material-symbols-outlined text-sm opacity-0 group-hover:opacity-100 transition-opacity text-white select-none">arrow_forward</span>
            </a>
            <a href="/items" class="flex items-center justify-between p-4 rounded-lg bg-surface-container/50 hover:bg-primary-600 group transition-all duration-300 cursor-pointer border border-transparent hover:border-primary-500/30">
              <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-primary-500 group-hover:text-white select-none">add_box</span>
                <span class="text-sm font-semibold text-gray-300 group-hover:text-white">Crear Ítem</span>
              </div>
              <span class="material-symbols-outlined text-sm opacity-0 group-hover:opacity-100 transition-opacity text-white select-none">arrow_forward</span>
            </a>
            <a href="/config" class="flex items-center justify-between p-4 rounded-lg bg-surface-container/50 hover:bg-primary-600 group transition-all duration-300 cursor-pointer border border-transparent hover:border-primary-500/30">
              <div class="flex items-center gap-3">
                <span class="material-symbols-outlined text-primary-500 group-hover:text-white select-none">settings</span>
                <span class="text-sm font-semibold text-gray-300 group-hover:text-white">Configuración</span>
              </div>
              <span class="material-symbols-outlined text-sm opacity-0 group-hover:opacity-100 transition-opacity text-white select-none">arrow_forward</span>
            </a>
          </div>
        </div>

        <div class="relative rounded-xl overflow-hidden h-40 shadow-[0_12px_32px_rgba(0,0,0,0.4)] group border border-outline-variant/10">
          <div class="absolute inset-0 bg-primary-900 overflow-hidden">
            <svg class="absolute inset-0 w-full h-full opacity-30" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <pattern id="grid" width="32" height="32" patternUnits="userSpaceOnUse">
                  <path d="M0 32V0h32" fill="none" stroke="currentColor" stroke-width="1"></path>
                </pattern>
              </defs>
              <rect width="100%" height="100%" fill="url(#grid)" class="text-primary-500/30"></rect>
            </svg>
          </div>
          <div class="absolute inset-0 bg-gradient-to-t from-primary-600/80 to-transparent flex flex-col justify-end p-6 z-10 hover:from-primary-500/90 transition-colors">
            <p class="text-[10px] font-black text-white/80 tracking-widest uppercase">Disponibilidad del Sistema</p>
            <h4 class="text-white text-2xl font-bold">99.98% Fiable</h4>
          </div>
        </div>
      </div>

    </div>

  </div>
</DashboardLayout>

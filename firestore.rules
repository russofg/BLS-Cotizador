rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ========================
    // HELPER FUNCTIONS
    // ========================
    
    // Check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Get user document data
    function getUserData() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }
    
    // Check if the user is an admin
    function isAdmin() {
      return isAuthenticated() && getUserData().rol == 'admin';
    }
    
    // Check if the user is active
    function isActiveUser() {
      return isAuthenticated() && getUserData().activo == true;
    }
    
    // Check if the user is an active admin
    function isActiveAdmin() {
      return isAdmin() && getUserData().activo == true;
    }
    
    // ========================
    // USUARIOS COLLECTION
    // ========================
    match /usuarios/{userId} {
      // Users can read their own profile
      allow read: if isAuthenticated() && request.auth.uid == userId;
      
      // Admins can read all user profiles
      allow read: if isActiveAdmin();
      
      // Users can update their own profile (limited fields)
      allow update: if isAuthenticated() 
        && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['rol', 'activo']);
      
      // Only admins can create users or change roles
      allow create: if isActiveAdmin() || (isAuthenticated() && request.auth.uid == userId);
      allow delete: if isActiveAdmin();
    }
    
    // ========================
    // COTIZACIONES COLLECTION
    // ========================
    match /cotizaciones/{cotizacionId} {
      // Any active authenticated user can read quotes
      allow read: if isActiveUser();
      
      // Any active authenticated user can create quotes
      allow create: if isActiveUser();
      
      // Any active authenticated user can update quotes
      allow update: if isActiveUser();
      
      // Only admins can delete quotes
      allow delete: if isActiveAdmin();
    }
    
    // ========================
    // CLIENTES COLLECTION
    // ========================
    match /clientes/{clienteId} {
      // Any active authenticated user can read clients
      allow read: if isActiveUser();
      
      // Any active authenticated user can create/update clients
      allow create, update: if isActiveUser();
      
      // Only admins can delete clients
      allow delete: if isActiveAdmin();
    }
    
    // ========================
    // VENUES COLLECTION
    // ========================
    match /venues/{venueId} {
      allow read: if isActiveUser();
      allow create, update: if isActiveUser();
      allow delete: if isActiveAdmin();
    }
    
    // ========================
    // ITEMS COLLECTION
    // ========================
    match /items/{itemId} {
      // Any active authenticated user can read items
      allow read: if isActiveUser();
      
      // Any active authenticated user can create/update items
      allow create, update: if isActiveUser();
      
      // Only admins can delete items
      allow delete: if isActiveAdmin();
    }
    
    // ========================
    // CATEGORIAS COLLECTION
    // ========================
    match /categorias/{categoriaId} {
      allow read: if isActiveUser();
      allow create, update: if isActiveUser();
      allow delete: if isActiveAdmin();
    }
    
    // ========================
    // CONFIGURACION COLLECTION
    // ========================
    match /configuracion/{configId} {
      // Any active user can read config
      allow read: if isActiveUser();
      
      // Only admins can modify config
      allow create, update, delete: if isActiveAdmin();
    }
    
    // ========================
    // FACTURAS COLLECTION (AFIP invoices)
    // ========================
    match /facturas/{facturaId} {
      allow read: if isActiveUser();
      allow create, update: if isActiveUser();
      allow delete: if isActiveAdmin();
    }
    
    // ========================
    // DENY ALL OTHER COLLECTIONS
    // ========================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
